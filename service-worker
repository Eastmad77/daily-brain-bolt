/* The Daily BrainBolt – Service Worker (bumped) */
const VERSION = 'v1.0.11';                 // bump this each deploy
const STATIC_CACHE = `dbb-static-${VERSION}`;
const RUNTIME_CACHE = `dbb-runtime-${VERSION}`;
const CORE = [
  '/',
  '/index.html',
  '/about.html',
  '/terms.html',
  '/privacy.html',
  '/contact.html',
  '/404.html',
  '/style.css',
  '/app.js',
  '/firebase-config.js',
  '/favicon.svg',
  '/app-icon.svg',
  '/header-graphic.svg',
  '/site.webmanifest',
  '/apple-touch-icon.png',
  '/icon-192.png',
  '/icon-512.png'
];

const isCsvRequest = (url) => {
  try {
    const u = new URL(url);
    return u.hostname.includes('googleusercontent.com')
        || (u.hostname.includes('google.com') && u.pathname.includes('/spreadsheets/'))
        || (u.searchParams.get('output') === 'csv');
  } catch { return false; }
};

self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(STATIC_CACHE).then((cache) => cache.addAll(CORE)).then(() => self.skipWaiting())
  );
});

self.addEventListener('activate', (event) => {
  event.waitUntil((async () => {
    const keys = await caches.keys();
    await Promise.all(keys.map((k) => {
      if (k !== STATIC_CACHE && k !== RUNTIME_CACHE) return caches.delete(k);
    }));
    await self.clients.claim();
  })());
});

async function networkFirst(req, { cacheName = RUNTIME_CACHE, timeoutMs = 8000 } = {}) {
  const cache = await caches.open(cacheName);
  const controller = new AbortController();
  const t = setTimeout(() => controller.abort(), timeoutMs);
  try {
    const fresh = await fetch(req, { signal: controller.signal, cache: 'no-store' });
    clearTimeout(t);
    if (fresh && fresh.ok) cache.put(req, fresh.clone());
    return fresh;
  } catch (err) {
    clearTimeout(t);
    const cached = await cache.match(req);
    if (cached) return cached;
    throw err;
  }
}

async function cacheFirst(req, { cacheName = STATIC_CACHE } = {}) {
  const cache = await caches.open(cacheName);
  const cached = await cache.match(req);
  if (cached) return cached;
  const resp = await fetch(req);
  if (resp && resp.ok) cache.put(req, resp.clone());
  return resp;
}

self.addEventListener('fetch', (event) => {
  const req = event.request;
  const url = new URL(req.url);
  if (req.method !== 'GET') return;

  // HTML navigations
  if (req.mode === 'navigate' || req.destination === 'document') {
    event.respondWith((async () => {
      try { return await networkFirst(req, { cacheName: RUNTIME_CACHE, timeoutMs: 7000 }); }
      catch {
        const c = await caches.open(STATIC_CACHE);
        return (await c.match('/index.html')) || Response.error();
      }
    })());
    return;
  }

  // Live/Bank CSV
  if (isCsvRequest(req.url)) {
    event.respondWith(networkFirst(req, { cacheName: RUNTIME_CACHE, timeoutMs: 8000 }));
    return;
  }

  // Static assets
  const dest = req.destination;
  if (['style','script','image','font','manifest'].includes(dest) ||
      url.pathname.endsWith('.svg') || url.pathname.endsWith('.png') || url.pathname.endsWith('.webmanifest')) {
    event.respondWith(cacheFirst(req, { cacheName: STATIC_CACHE }));
    return;
  }

  // Default
  event.respondWith((async () => {
    try { return await fetch(req); }
    catch {
      const cache = await caches.open(RUNTIME_CACHE);
      const cached = await cache.match(req);
      if (cached) return cached;
      if (url.origin === location.origin) {
        const sc = await caches.open(STATIC_CACHE);
        return (await sc.match('/index.html')) || Response.error();
      }
      return Response.error();
    }
  })());
});

self.addEventListener('message', (event) => {
  if (event.data === 'SKIP_WAITING') self.skipWaiting();
});
